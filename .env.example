# Gmail Enhanced MCP Configuration

# Path to OAuth2 client secret (downloaded from Google Cloud Console)
GOOGLE_CLIENT_SECRET_PATH=credentials/client_secret.json

# Path to stored OAuth token (auto-generated after auth flow)
GOOGLE_TOKEN_PATH=credentials/token.json

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=mcp_server.log
