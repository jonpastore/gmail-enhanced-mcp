# Gmail Enhanced MCP Configuration

# Path to OAuth2 client secret (downloaded from Google Cloud Console)
GOOGLE_CLIENT_SECRET_PATH=credentials/client_secret.json

# Path to accounts config
ACCOUNTS_PATH=accounts.json

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=mcp_server.log

# Bearer token for HTTP transport authentication
MCP_AUTH_TOKEN=your-secret-bearer-token-here

# HTTP server port
HTTP_PORT=8420
